# 代理API配置
PROXY_API_KEY=
PROXY_API_SIGN=

# 代理账号密码（用于IP提取时的身份验证）
PROXY_USERNAME=
PROXY_PASSWORD=

# 其他配置
# PROXY_LIFETIME=300  # 代理生命周期（秒），默认5分钟
# MIN_INTERVAL=10     # API调用最小间隔（秒）

# 静态站点配置
# 搜索结果会发布到 data/ 下，并由 serve_searches.py 对外提供访问
PUBLIC_SITE_HOST=your-server-host
PUBLIC_SITE_PORT=38128
PUBLIC_SITE_BASE_URL=http://your-server-host:38128
SITE_SERVER_HOST=0.0.0.0

# 站点登录密码（建议用 set_site_password.py 生成）
SITE_PASSWORD_SALT=
SITE_PASSWORD_HASH=
SITE_SESSION_SECRET=
REFERENCE_EXPAND_LIMIT=20
AI4SCHOLAR_API_KEY=
