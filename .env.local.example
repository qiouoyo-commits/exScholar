# exScholar runtime configuration
#
# Copy this file to `.env.local` and adjust values for your deployment.
# The project now runs uniformly in the `openclaw-analytics` conda environment.

# ------------------------------------------------------------------------------
# Site / HTTP service
# ------------------------------------------------------------------------------

# Public URL used to build absolute links in search results and reading pages.
PUBLIC_SITE_BASE_URL=http://your-server-host:38128

# Public-facing host hint for generated URLs.
PUBLIC_SITE_HOST=your-server-host

# HTTP port exposed by exScholar.
PUBLIC_SITE_PORT=38128

# Bind address for the local HTTP server.
SITE_SERVER_HOST=0.0.0.0


# ------------------------------------------------------------------------------
# Authentication / session
# ------------------------------------------------------------------------------

# These values are maintained by `set_site_password.py`.
# In the current multi-user setup, real user accounts are stored in
# `data/users/users.json`. Keeping these values is still useful for admin
# compatibility and session signing.
SITE_PASSWORD_SALT=
SITE_PASSWORD_HASH=
SITE_SESSION_SECRET=


# ------------------------------------------------------------------------------
# OpenClaw / model configuration
# ------------------------------------------------------------------------------

OPENCLAW_INGEST_MODEL=joybuilder-plan/DeepSeek-V3.2
OPENCLAW_INGEST_CHECK_MODEL=joybuilder-plan/GLM-5
OPENCLAW_INGEST_FALLBACK_MODEL=joybuilder-plan/Kimi-K2.5
OPENCLAW_CONFIG_PATH=/home/ubuntu/.openclaw/openclaw.json

# Unified Python interpreter used by research subprocesses and service tooling.
OPENCLAW_ANALYTICS_PYTHON=/home/ubuntu/miniconda3/envs/openclaw-analytics/bin/python

# Optional HTTP proxy used only by the DuckDuckGo web fallback in
# `app/openclaw/paper_lookup.py`. Keep this empty unless your deployment
# environment blocks direct access to DuckDuckGo.
DUCKDUCKGO_HTTP_PROXY=

# Default user for non-web OpenClaw intake and default external research flows.
OPENCLAW_DEFAULT_USERNAME=qioyo


# ------------------------------------------------------------------------------
# Search / expansion behavior
# ------------------------------------------------------------------------------

REFERENCE_EXPAND_LIMIT=20
MAX_CONCURRENT_RESEARCH_JOBS=2


# ------------------------------------------------------------------------------
# Optional external integrations
# ------------------------------------------------------------------------------

AI4SCHOLAR_API_KEY=


# ------------------------------------------------------------------------------
# Optional proxy configuration used by parts of the crawler stack
# ------------------------------------------------------------------------------

PROXY_API_KEY=
PROXY_API_SIGN=
PROXY_USERNAME=
PROXY_PASSWORD=

# Optional legacy tuning values for proxy/crawler flows.
# PROXY_LIFETIME=300
# MIN_INTERVAL=10


# ------------------------------------------------------------------------------
# Optional debug / override paths
# ------------------------------------------------------------------------------

# These are usually injected by scripts such as `run_search.sh` and do not need
# to be set in normal deployments.
# EXSCHOLAR_DATA_DIR=
# EXSCHOLAR_SEARCHES_DIR=
# EXSCHOLAR_TMP_SEARCH_DIR=
